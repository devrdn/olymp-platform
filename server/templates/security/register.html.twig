{% extends 'base.html.twig' %}

{% block title %}Register
{% endblock %}

{% block body %}
	<section class="register">
		<div class="bg-main p-8 max-w-md mx-auto">

			{{ form_start(registrationForm) }}

			{{ form_start(registrationForm) }}
			<div class="flex flex-col">
				{{ form_label(registrationForm.email) }}
				{{ form_widget(registrationForm.email) }}
                <span class="text-red-400">{{ form_errors(registrationForm.email) }}</span>
			</div>

			<div class="form-group mt-10">
				{{ form_label(registrationForm.plainPassword.first) }}
				{{ form_widget(registrationForm.plainPassword.first) }}
			</div>

			<div class="form-group mt-10">
				{{ form_label(registrationForm.plainPassword.second) }}
				{{ form_widget(registrationForm.plainPassword.second) }}
                <span class="text-red-400">{{ form_errors(registrationForm.plainPassword.first) }}</span>
			</div>

			<div class="form-group mt-10">
				{{ form_label(registrationForm.name) }}
				{{ form_widget(registrationForm.name) }}
				<span class="text-red-400">{{ form_errors(registrationForm.name) }}</span>
			</div>

			<div class="form-group mt-10">
				{{ form_label(registrationForm.username) }}
				{{ form_widget(registrationForm.username) }}
				<span>
				{{ form_errors(registrationForm.username) }}
				<span class="text-red-400">{{ form_errors(registrationForm.username) }}</span>
			</span>
			</div>

			<button type="submit" class="btn-link mt-10">Register</button>
			{{ form_end(registrationForm) }}
		</div>
	</section>
{% endblock %}
