{% extends 'base.html.twig' %}

{% block title %}
    {{ task.name }}
{% endblock %}

{% block body %}
    <div class="bg-main max-w-3xl mx-auto px-24 py-10">
        <div id="task" class="task-{{ task.id }} flex flex-col text-lg">
            <h1 id="task-name" class="font-bold text-center text-5xl">{{ task.name }}</h1>
            <div id="task-description" class="mt-4">
                <h2>Description</h2>
                <hr class="border border-blue-500"/>
                <div class="text-xl mt-4 font-semibold">{{ task.description | raw }}</div>
            </div>
            <div id="task-time_limit" class="mt-4">
                <h2>Time Limit</h2>
                <hr class="border border-blue-500"/>
                <div class="text-xl mt-4 font-semibold">{{ task.timeLimit }}s</div>
            </div>
            <div id="task-mem_limit" class="mt-4">
                <h2>Memory Limit</h2>
                <hr class="border border-blue-500"/>
                <div class="text-xl mt-4 font-semibold">{{ task.memoryLimit }}mb</div>
            </div>
            <div id="task-example" class="flex flex-row gap-5 mt-4">
                <div class="w-full">
                    <h2>Example Input</h2>
                    <hr class="border border-blue-500"/>
                    <div class="text-xl mt-4 font-semibold">{{ task.exampleInput|raw }}</div>
                </div>
                <div class="w-full">
                    <h2>Example Input</h2>
                    <hr class="border border-blue-500"/>
                    <div class="text-xl mt-4 font-semibold">{{ task.exampleInput|raw }}</div>
                </div>
            </div>
            <div id="task-author" class="mt-4">
                <h2>Author</h2>
                <hr class="border border-blue-500"/>
                <div class="text-xl mt-4 font-semibold">{{ task.taskMeta.author }}</div>
            </div>
            <div id="task-upload" class="mt-10">
                {% include "task/_upload_solution.html.twig" with { form: form } %}
            </div>
        </div>
    </div>
    {% if app.user %}
    <table class="table-fixed max-w-3xl mx-auto px-24 py-10 w-full mt-10">
        <thead class="text-xl bg-main">
        <tr class="border-b-2 border-gray-600">
            <th class="font-semibold py-3 px-4">№</th>
            <th class="font-semibold py-3 px-4">Status</th>
        </tr>
        </thead>
        <tbody id="solutions">
        <tr class="font-medium bg-main text-center text-lg">
            <td class="animate-pulse p-3">Loading...</td>
            <td class="animate-pulse p-3">Loading...</td>
        </tr>
        </tbody>
    </table>
{% endif %}
{% endblock %}

{% block script %}
    <script src="/utils/tabs.js"></script>
    {% if app.user %}
        <script>
            const userId = {{ app.user.id }};
            const taskId = {{ task.Id }};
            const taskStatus = document.querySelector("#solutions");

            console.log(taskStatus)

            const onSuccess = (status) => {
                status.json().then(item => {
                    let html = "";
                    const len = item.tasks.length;

                    item.tasks.forEach((item, i) => {
                        const extraClass = i % 2 === 0 ? "bg-table" : "bg-main";
                        html += `<tr class="font-medium  ${extraClass} text-center text-lg"><td class="p-3">${len - i}</td><td  class="p-3">${item.task_status.name}</td><tr>`;
                    })

                    taskStatus.innerHTML = html;

                }).catch(() => {
                    taskStatus.innerHTML = `<tr class="font-medium bg-main text-center text-lg"><td class="p-3">-</td><td  class="p-3">-</td><tr>`;
                    clearInterval(interval);
                })
            }

            const onError = (status) => {
                console.log("FDs");
                status.json().then(item => {
                    taskStatus.innerHTML = `<tr class="font-medium  ${extraClass} text-center text-lg"><td class="p-3">-</td><td  class="p-3">-</td><tr>`;
                });
                clearInterval(interval);
            }

            const handleInfo = (onSuccess, onError) => {
                fetch(`/api/v1/tasks/${userId}/${taskId}`).then((status) => {
                    onSuccess(status);
                }).catch((err) => {
                    onError(err);
                })
            }

            const interval = setInterval(() => {
                handleInfo(onSuccess, onError);
            }, 2000);
        </script>
    {% endif %}
{% endblock %}
