{% extends 'base.html.twig' %}

{% block title %}Home{% endblock %}

{% block body %}
    <section id="greeting">
        <div id="greeting-text" class="flex md:flex-row flex-col items-center justify-between">
            <div class="md:w-1/2 w-full md:space-y-8 space-y-5">
                <p class="text-6xl font-bold">Hello, world!</p>
                <p class="text-lg font-medium">
                    Welcome to our platform for programming competitions! Here you will find all the information you
                    need about upcoming competitions, and you can also practice before upcoming events.
                    We created this site to help students develop their programming skills and prepare them for
                    their future careers in the IT industry.
                </p>
                <a href="/login" class="inline-flex text-lg font-semibold items-center space-x-3 btn-link">
                    <span>Sign In</span>
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M7.3 15.3C7.11667 15.1167 7.02067 14.8833 7.012 14.6C7.00334 14.3167 7.091 14.0833 7.275 13.9L12.175 8.99999H1C0.71667 8.99999 0.479004 8.90399 0.287004 8.71199C0.0950036 8.51999 -0.000663206 8.28265 3.4602e-06 7.99999C3.4602e-06 7.71665 0.0960036 7.47899 0.288004 7.28699C0.480004 7.09499 0.717337 6.99932 1 6.99999H12.175L7.275 2.09999C7.09167 1.91665 7.004 1.68332 7.012 1.39999C7.02 1.11665 7.116 0.883321 7.3 0.699987C7.48334 0.516654 7.71667 0.424988 8 0.424988C8.28334 0.424988 8.51667 0.516654 8.7 0.699987L15.3 7.29999C15.4 7.38332 15.471 7.48765 15.513 7.61299C15.555 7.73832 15.5757 7.86732 15.575 7.99999C15.575 8.13332 15.5543 8.25832 15.513 8.37499C15.4717 8.49165 15.4007 8.59999 15.3 8.69999L8.7 15.3C8.51667 15.4833 8.28334 15.575 8 15.575C7.71667 15.575 7.48334 15.4833 7.3 15.3Z"
                              fill="white"></path>
                    </svg>
                </a>
            </div>
            <div id="code" class="md:w-auto md:mt-0 mt-5 w-full">
                <div class="bg-main">
                    <div id="code-header">
                        <div class="flex flex-row items-center py-4 px-3 position-relative space-x-2">
                            <div class="h-[15px] w-[15px] rounded-full bg-blue-700 cursor-pointer"></div>
                            <div class="h-[15px] w-[15px] rounded-full bg-teal-800 cursor-pointer"></div>
                            <div class="h-[15px] w-[15px] rounded-full bg-emerald-700 cursor-pointer"></div>
                        </div>
                    </div>
                    <hr class="border-slate-600"/>
                    <div class="font-mono py-4 px-5 pr-14">
                        {% include('/home/partials/_code.html.twig') %}
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="contests" class="mt-24">
        <div class="space-y-10">
            <h1 class="text-5xl font-bold">Contests</h1>
            <div class="grid lg:grid-cols-3 gap-5 md:grid-cols-2 grid-cols-1">
                {% include '/home/partials/_contest.html.twig' with { contest_id: 1 } %}
                {% include '/home/partials/_contest.html.twig' with { contest_id: 2 } %}
                {% include '/home/partials/_contest.html.twig' with { contest_id: 3 } %}
                {% include '/home/partials/_contest.html.twig' with { contest_id: 4 } %}
                {% include '/home/partials/_contest.html.twig' with { contest_id: 4 } %}
                {% include '/home/partials/_contest.html.twig' with { contest_id: 4 } %}
            </div>
        </div>
    </section>


